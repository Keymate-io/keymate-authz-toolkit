          "tenant_id": "T-001",
          "invoice_id": "INV-456"
        },
        "request": {
          "target_method": "GET",
          "target_uri": "/api/v1/tenants/T-001/invoices/INV-456",
          "channel": "AGENT"
        }
      },
      "expected": {
        "matcherDecision": "MATCH",
        "matchedRuleId": "agent.invoice.read",
        "celDecision": "DENY",
        "finalDecision": "DENY",
        "failedConditions": [
          "agent.trust_level >= 3"
        ]
      }
    },
